# --- Database ---
# SQLite (default, good for dev / single-node Railway with a volume):
DATABASE_URL="file:./data/asset-manager.db"
# Postgres (Railway): switch provider in prisma/schema.prisma to "postgresql" and use:
# DATABASE_URL="postgresql://user:pass@host:5432/dbname"

# --- Auth ---
# Any long random string; used to sign session JWTs.
AUTH_SECRET="generate-a-long-random-string"

# --- App ---
# Public base URL of the deployment; used as the default QR-label base URL.
APP_URL="http://localhost:3000"

# --- File storage ---
# "local" stores files under UPLOADS_DIR and serves them via /api/files/...
# "supabase" stores files in a Supabase Storage bucket.
STORAGE_DRIVER="local"
UPLOADS_DIR="./data/uploads"
# SUPABASE_URL="https://xxxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="service-role-key"
# SUPABASE_BUCKET="asset-manager"
